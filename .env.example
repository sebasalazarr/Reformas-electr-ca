# Copia este archivo a ".env" para probar localmente con `vercel dev`.
# En producción (Vercel) estas variables se configuran en:
# Project Settings -> Environment Variables. Nunca subas tu ".env" real a git.

# Descomenta y completa SOLO la que vayas a usar según el proveedor activo
# en api/chat.js (por defecto: OpenAI).

OPENAI_API_KEY=
